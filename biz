<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>JuleskLocal — Business Profile</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,700&family=Karla:wght@300;400;500;600&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
  :root { --ink:#1A1410;--paper:#F7F3EC;--rust:#B85C38;--warm:#E8DFD0;--sage:#4A6741;--gold:#C9973A;--muted:#9A8E7E;--border:rgba(44,36,22,0.12); }
  *{margin:0;padding:0;box-sizing:border-box;}
  body{background:var(--paper);color:var(--ink);font-family:'Karla',sans-serif;font-weight:300;min-height:100vh;}

  nav{padding:1.25rem 2.5rem;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid var(--border);background:var(--paper);position:sticky;top:0;z-index:100;}
  .logo{font-family:'Cormorant Garamond',serif;font-size:1.5rem;font-weight:700;color:var(--ink);text-decoration:none;}
  .logo span{color:var(--rust);font-style:italic;}
  .nav-back{font-size:0.82rem;color:var(--muted);text-decoration:none;transition:color 0.2s;}
  .nav-back:hover{color:var(--ink);}

  /* HERO */
  .biz-hero{background:var(--ink);padding:3.5rem 2.5rem 2.5rem;position:relative;overflow:hidden;}
  .biz-hero::before{content:'';position:absolute;width:500px;height:500px;background:radial-gradient(circle,rgba(184,92,56,0.12) 0%,transparent 70%);border-radius:50%;top:-200px;right:-150px;pointer-events:none;}
  .promoted-banner{background:var(--gold);color:var(--ink);font-size:0.65rem;letter-spacing:0.15em;text-transform:uppercase;font-weight:700;padding:0.4rem 1rem;border-radius:0.3rem;display:inline-block;margin-bottom:1rem;}
  .biz-category{font-size:0.72rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--rust);margin-bottom:0.75rem;font-weight:500;}
  .biz-name{font-family:'Cormorant Garamond',serif;font-size:clamp(2.2rem,5vw,4rem);font-weight:700;color:var(--paper);line-height:1.05;margin-bottom:0.5rem;letter-spacing:-0.02em;}
  .biz-location{font-size:0.92rem;color:rgba(247,243,236,0.5);margin-bottom:1.5rem;}
  .biz-desc-hero{font-size:1rem;color:rgba(247,243,236,0.7);line-height:1.75;max-width:600px;margin-bottom:2rem;}

  /* ACTION BUTTONS */
  .action-row{display:flex;gap:0.75rem;flex-wrap:wrap;}
  .action-btn{display:inline-flex;align-items:center;gap:0.5rem;padding:0.75rem 1.5rem;border-radius:2rem;font-family:'Karla',sans-serif;font-size:0.88rem;font-weight:500;text-decoration:none;transition:all 0.2s;cursor:pointer;border:none;}
  .action-btn.primary{background:var(--rust);color:white;}
  .action-btn.primary:hover{opacity:0.88;}
  .action-btn.outline{background:transparent;color:var(--paper);border:1.5px solid rgba(247,243,236,0.25);}
  .action-btn.outline:hover{border-color:var(--paper);}
  .action-btn.gold{background:var(--gold);color:var(--ink);}
  .action-btn.gold:hover{opacity:0.88;}

  /* MAIN CONTENT */
  .biz-body{max-width:1000px;margin:0 auto;padding:3rem 2.5rem;display:grid;grid-template-columns:1fr 320px;gap:3rem;align-items:start;}

  /* LEFT */
  .section{margin-bottom:2.5rem;}
  .section-title{font-family:'Cormorant Garamond',serif;font-size:1.3rem;font-weight:700;margin-bottom:1rem;padding-bottom:0.5rem;border-bottom:1px solid var(--border);}
  .detail-grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem;}
  .detail-item{background:white;border:1px solid var(--border);border-radius:0.75rem;padding:1rem 1.25rem;}
  .detail-label{font-size:0.65rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);margin-bottom:0.3rem;display:block;}
  .detail-value{font-size:0.9rem;color:var(--ink);font-weight:400;word-break:break-word;}
  .detail-value a{color:var(--rust);text-decoration:none;}
  .detail-value a:hover{text-decoration:underline;}

  /* SOCIAL */
  .social-row{display:flex;gap:0.75rem;flex-wrap:wrap;margin-top:0.5rem;}
  .social-btn{display:inline-flex;align-items:center;gap:0.4rem;padding:0.5rem 1rem;border-radius:2rem;border:1.5px solid var(--border);font-size:0.8rem;text-decoration:none;color:var(--ink);transition:all 0.2s;background:white;}
  .social-btn:hover{border-color:var(--rust);color:var(--rust);}

  /* AI SECTION */
  .ai-box{background:white;border:1.5px solid var(--border);border-radius:1rem;padding:1.5rem;margin-top:1.5rem;}
  .ai-box-label{font-size:0.65rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--rust);margin-bottom:0.75rem;display:block;font-weight:500;}
  .ai-box-text{font-size:0.88rem;color:var(--muted);line-height:1.75;min-height:60px;}
  .ai-box-text.loading{display:flex;align-items:center;gap:0.5rem;font-style:italic;}

  /* RIGHT SIDEBAR */
  .sidebar{position:sticky;top:6rem;}
  .sidebar-card{background:white;border:1.5px solid var(--border);border-radius:1rem;padding:1.5rem;margin-bottom:1.25rem;}
  .sidebar-card-title{font-family:'Cormorant Garamond',serif;font-size:1.1rem;font-weight:700;margin-bottom:1rem;}
  .sidebar-link{display:flex;align-items:center;gap:0.75rem;padding:0.75rem 0;border-bottom:1px solid var(--border);text-decoration:none;color:var(--ink);transition:color 0.2s;font-size:0.88rem;}
  .sidebar-link:last-child{border-bottom:none;padding-bottom:0;}
  .sidebar-link:hover{color:var(--rust);}
  .sidebar-link-icon{font-size:1.1rem;width:24px;text-align:center;flex-shrink:0;}
  .sidebar-link-label{flex:1;}
  .sidebar-link-arrow{color:var(--muted);font-size:0.75rem;}

  .hours-box{background:var(--warm);border-radius:0.5rem;padding:0.75rem 1rem;font-size:0.85rem;color:var(--ink);line-height:1.6;}

  .promote-card{background:var(--ink);border-radius:1rem;padding:1.5rem;color:var(--paper);}
  .promote-card h3{font-family:'Cormorant Garamond',serif;font-size:1.2rem;font-weight:700;margin-bottom:0.5rem;}
  .promote-card p{font-size:0.8rem;color:rgba(247,243,236,0.55);line-height:1.6;margin-bottom:1.25rem;}
  .promote-btn{display:block;background:var(--gold);color:var(--ink);text-align:center;padding:0.75rem;border-radius:2rem;font-family:'Karla',sans-serif;font-size:0.85rem;font-weight:600;text-decoration:none;transition:opacity 0.2s;}
  .promote-btn:hover{opacity:0.88;}

  /* INSURANCE TAG */
  .insurance-tag{display:inline-block;background:rgba(74,103,65,0.1);border:1px solid rgba(74,103,65,0.25);color:var(--sage);padding:0.3rem 0.75rem;border-radius:2rem;font-size:0.78rem;margin:0.25rem;}

  /* LOADING / ERROR */
  .full-loading{min-height:60vh;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:1rem;color:var(--muted);}
  .spinner{width:24px;height:24px;border:2px solid var(--border);border-top-color:var(--rust);border-radius:50%;animation:spin 0.7s linear infinite;}
  @keyframes spin{to{transform:rotate(360deg);}}

  /* SHARE */
  .share-row{display:flex;gap:0.5rem;align-items:center;margin-top:1rem;}
  .share-url{flex:1;background:var(--warm);border:1px solid var(--border);border-radius:0.4rem;padding:0.6rem 0.85rem;font-size:0.78rem;color:var(--muted);font-family:'Karla',sans-serif;outline:none;cursor:text;}
  .copy-btn{background:var(--ink);color:white;border:none;padding:0.6rem 1rem;border-radius:0.4rem;font-family:'Karla',sans-serif;font-size:0.75rem;cursor:pointer;white-space:nowrap;transition:opacity 0.2s;}
  .copy-btn:hover{opacity:0.8;}

  @media(max-width:768px){
    .biz-body{grid-template-columns:1fr;gap:2rem;}
    .sidebar{position:static;}
    .detail-grid{grid-template-columns:1fr;}
    nav{padding:1rem 1.25rem;}
    .biz-hero{padding:2.5rem 1.25rem 2rem;}
  }
</style>
</head>
<body>

<nav>
  <a href="index.html" class="logo">Julesk<span>Local</span></a>
  <a href="search.html" class="nav-back">← Back to search</a>
</nav>

<div id="loadingState" class="full-loading">
  <div class="spinner"></div>
  <span>Loading business profile...</span>
</div>

<div id="bizContent" style="display:none;">
  <!-- HERO -->
  <div class="biz-hero">
    <div id="promotedBanner" style="display:none;"><span class="promoted-banner">⭐ Featured Business</span></div>
    <div class="biz-category" id="bizCategory"></div>
    <h1 class="biz-name" id="bizName"></h1>
    <div class="biz-location" id="bizLocation"></div>
    <div class="biz-desc-hero" id="bizDesc"></div>
    <div class="action-row" id="actionRow"></div>
  </div>

  <!-- BODY -->
  <div class="biz-body">
    <div class="left-col">

      <div class="section" id="detailsSection">
        <div class="section-title">Business Details</div>
        <div class="detail-grid" id="detailGrid"></div>
      </div>

      <div class="section" id="insuranceSection" style="display:none;">
        <div class="section-title">Insurance Accepted</div>
        <div id="insuranceTags"></div>
      </div>

      <div class="section" id="socialSection" style="display:none;">
        <div class="section-title">Follow & Connect</div>
        <div class="social-row" id="socialRow"></div>
      </div>

      <div class="ai-box">
        <span class="ai-box-label">About this business — AI Summary</span>
        <div class="ai-box-text loading" id="aiSummary">
          <div class="spinner" style="width:16px;height:16px;border-color:rgba(0,0,0,0.1);border-top-color:var(--rust);"></div>
          <span>Generating summary...</span>
        </div>
      </div>

      <div class="section" style="margin-top:2rem;">
        <div class="section-title">Share This Business</div>
        <p style="font-size:0.85rem;color:var(--muted);margin-bottom:0.75rem;">Know someone who needs this service? Share their profile.</p>
        <div class="share-row">
          <input class="share-url" id="shareUrl" readonly>
          <button class="copy-btn" onclick="copyShare()">Copy Link</button>
        </div>
      </div>

    </div>

    <div class="sidebar">
      <div class="sidebar-card" id="quickLinksCard">
        <div class="sidebar-card-title">Quick Links</div>
        <div id="quickLinks"></div>
      </div>

      <div class="sidebar-card" id="hoursCard" style="display:none;">
        <div class="sidebar-card-title">Hours</div>
        <div class="hours-box" id="hoursBox"></div>
      </div>

      <div class="promote-card">
        <h3>Boost this listing</h3>
        <p>Help more people find this business by promoting them to the top of search results.</p>
        <a href="promote.html" class="promote-btn">Learn About Featured Listings</a>
      </div>
    </div>
  </div>
</div>

<div id="errorState" style="display:none;" class="full-loading">
  <h2 style="font-family:'Cormorant Garamond',serif;font-size:2rem;">Business not found</h2>
  <p style="font-size:0.9rem;">This listing may have been removed or the link is incorrect.</p>
  <a href="search.html" style="color:var(--rust);text-decoration:none;font-size:0.9rem;">← Back to search</a>
</div>

<script>
  const SUPABASE_URL = 'https://kmugbwcwonygkzkiblqf.supabase.co';
  const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImttdWdid2N3b255Z2t6a2libHFmIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzc4MDUyNDQsImV4cCI6MjA5MzM4MTI0NH0.JypfbLZ1HkLHMlAvAzzo98yi3WOdnatZPCmxMDG6dNk';
  const { createClient } = supabase;
  const db = createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

  const slug = new URLSearchParams(window.location.search).get('slug');

  async function load() {
    if (!slug) { showError(); return; }

    const { data, error } = await db
      .from('businesses')
      .select('*')
      .eq('slug', slug)
      .eq('is_active', true)
      .single();

    if (error || !data) { showError(); return; }

    // Track view
    await db.from('profile_views').insert([{ business_id: data.id }]);

    renderBiz(data);
    generateAISummary(data);
  }

  function renderBiz(b) {
    document.title = `${b.business_name} — JuleskLocal`;

    // Hero
    if (b.is_promoted) document.getElementById('promotedBanner').style.display = 'block';
    document.getElementById('bizCategory').textContent = b.category;
    document.getElementById('bizName').textContent = b.business_name;
    document.getElementById('bizLocation').textContent = `📍 ${b.city}${b.state ? ', ' + b.state : ''}`;
    document.getElementById('bizDesc').textContent = b.description || '';

    // Action buttons
    const actions = [];
    if (b.scheduler_link) actions.push(`<a class="action-btn primary" href="${b.scheduler_link}" target="_blank" onclick="track('${b.id}','scheduler','${b.scheduler_link}')">📅 Book Appointment</a>`);
    if (b.phone) actions.push(`<a class="action-btn outline" href="tel:${b.phone}" onclick="track('${b.id}','phone','${b.phone}')">📞 Call Now</a>`);
    if (b.website) actions.push(`<a class="action-btn outline" href="${b.website}" target="_blank" onclick="track('${b.id}','website','${b.website}')">🌐 Website</a>`);
    if (b.pricing_link) actions.push(`<a class="action-btn gold" href="${b.pricing_link}" target="_blank" onclick="track('${b.id}','pricing','${b.pricing_link}')">💰 View Pricing</a>`);
    document.getElementById('actionRow').innerHTML = actions.join('');

    // Details grid
    const details = [];
    if (b.phone) details.push({ label: 'Phone', value: `<a href="tel:${b.phone}">${b.phone}</a>` });
    if (b.website) details.push({ label: 'Website', value: `<a href="${b.website}" target="_blank">Visit site →</a>` });
    if (b.pricing_link) details.push({ label: 'Pricing', value: `<a href="${b.pricing_link}" target="_blank">View prices →</a>` });
    if (b.scheduler_link) details.push({ label: 'Booking', value: `<a href="${b.scheduler_link}" target="_blank">Book now →</a>` });
    if (b.city) details.push({ label: 'Location', value: `${b.city}${b.state ? ', ' + b.state : ''}` });
    if (b.category) details.push({ label: 'Category', value: b.category });

    document.getElementById('detailGrid').innerHTML = details.map(d =>
      `<div class="detail-item"><span class="detail-label">${d.label}</span><div class="detail-value">${d.value}</div></div>`
    ).join('');

    // Insurance
    if (b.insurance_accepted) {
      document.getElementById('insuranceSection').style.display = 'block';
      document.getElementById('insuranceTags').innerHTML = b.insurance_accepted
        .split(',').map(i => `<span class="insurance-tag">✓ ${i.trim()}</span>`).join('');
    }

    // Social
    const socials = [];
    if (b.instagram) socials.push(`<a class="social-btn" href="${b.instagram}" target="_blank">📸 Instagram</a>`);
    if (b.facebook) socials.push(`<a class="social-btn" href="${b.facebook}" target="_blank">👍 Facebook</a>`);
    if (b.tiktok) socials.push(`<a class="social-btn" href="${b.tiktok}" target="_blank">🎵 TikTok</a>`);
    if (b.youtube) socials.push(`<a class="social-btn" href="${b.youtube}" target="_blank">▶️ YouTube</a>`);
    if (socials.length) {
      document.getElementById('socialSection').style.display = 'block';
      document.getElementById('socialRow').innerHTML = socials.join('');
    }

    // Hours
    if (b.hours) {
      document.getElementById('hoursCard').style.display = 'block';
      document.getElementById('hoursBox').textContent = b.hours;
    }

    // Quick links sidebar
    const qlinks = [];
    if (b.scheduler_link) qlinks.push(`<a class="sidebar-link" href="${b.scheduler_link}" target="_blank"><span class="sidebar-link-icon">📅</span><span class="sidebar-link-label">Book Appointment</span><span class="sidebar-link-arrow">→</span></a>`);
    if (b.phone) qlinks.push(`<a class="sidebar-link" href="tel:${b.phone}"><span class="sidebar-link-icon">📞</span><span class="sidebar-link-label">${b.phone}</span><span class="sidebar-link-arrow">→</span></a>`);
    if (b.website) qlinks.push(`<a class="sidebar-link" href="${b.website}" target="_blank"><span class="sidebar-link-icon">🌐</span><span class="sidebar-link-label">Website</span><span class="sidebar-link-arrow">→</span></a>`);
    if (b.pricing_link) qlinks.push(`<a class="sidebar-link" href="${b.pricing_link}" target="_blank"><span class="sidebar-link-icon">💰</span><span class="sidebar-link-label">View Pricing</span><span class="sidebar-link-arrow">→</span></a>`);
    if (!qlinks.length) qlinks.push(`<p style="font-size:0.82rem;color:var(--muted);">No links added yet.</p>`);
    document.getElementById('quickLinks').innerHTML = qlinks.join('');

    // Share URL
    document.getElementById('shareUrl').value = `https://julesk.online/biz.html?slug=${b.slug}`;

    // Show content
    document.getElementById('loadingState').style.display = 'none';
    document.getElementById('bizContent').style.display = 'block';
  }

  async function track(bizId, type, url) {
    await db.from('link_clicks').insert([{ business_id: bizId, link_type: type, link_url: url }]);
  }

  function copyShare() {
    navigator.clipboard.writeText(document.getElementById('shareUrl').value);
    document.querySelector('.copy-btn').textContent = 'Copied!';
    setTimeout(() => document.querySelector('.copy-btn').textContent = 'Copy Link', 2000);
  }

  function showError() {
    document.getElementById('loadingState').style.display = 'none';
    document.getElementById('errorState').style.display = 'flex';
  }

  async function generateAISummary(b) {
    const el = document.getElementById('aiSummary');
    try {
      const prompt = `Write a 2-3 sentence friendly summary of this local business for potential customers. Make it warm, specific, and helpful. Focus on what they offer and who they serve.

Business: ${b.business_name}
Category: ${b.category}
Location: ${b.city}${b.state ? ', ' + b.state : ''}
Description: ${b.description || 'not provided'}
Has booking: ${!!b.scheduler_link}
Has pricing info: ${!!b.pricing_link}
Insurance accepted: ${b.insurance_accepted || 'not specified'}

Write only the summary, no labels or preamble.`;

      const response = await fetch('https://api.anthropic.com/v1/messages', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          model: 'claude-sonnet-4-20250514',
          max_tokens: 300,
          messages: [{ role: 'user', content: prompt }]
        })
      });
      const data = await response.json();
      const text = data.content?.find(c => c.type === 'text')?.text || '';
      el.classList.remove('loading');
      el.textContent = text;
    } catch {
      el.classList.remove('loading');
      el.textContent = `${b.business_name} is a ${b.category.toLowerCase()} based in ${b.city}. ${b.description || 'Contact them directly for more information.'}`;
    }
  }

  load();
</script>
</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>JuleskLocal — My Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400;500&family=Syne:wght@400;600;700;800&family=Karla:wght@300;400;500&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
  :root{--bg:#0D0D0D;--surface:#141414;--border:#222;--rust:#C4622D;--gold:#D4A843;--sage:#4A7A47;--text:#E8E4DC;--muted:#555;--dim:#2A2A2A;--paper:#F7F3EC;}
  *{margin:0;padding:0;box-sizing:border-box;}
  body{background:var(--bg);color:var(--text);font-family:'Karla',sans-serif;font-weight:300;min-height:100vh;}

  /* LOGIN */
  .login-screen{min-height:100vh;display:flex;align-items:center;justify-content:center;background:var(--bg);}
  .login-box{width:100%;max-width:400px;padding:2.5rem;}
  .login-logo{font-family:'Syne',sans-serif;font-size:1.2rem;font-weight:700;margin-bottom:0.3rem;}
  .login-logo span{color:var(--rust);}
  .login-sub{font-size:0.72rem;color:var(--muted);letter-spacing:0.1em;text-transform:uppercase;margin-bottom:2.5rem;}
  .login-label{font-size:0.68rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--muted);margin-bottom:0.5rem;display:block;}
  .login-input{width:100%;background:var(--surface);border:1px solid var(--border);border-radius:0.4rem;padding:0.85rem 1rem;color:var(--text);font-family:'Karla',sans-serif;font-size:0.92rem;outline:none;transition:border-color 0.2s;margin-bottom:1rem;}
  .login-input:focus{border-color:var(--rust);}
  .login-input::placeholder{color:var(--muted);}
  .login-btn{width:100%;background:var(--rust);color:white;border:none;padding:0.85rem;border-radius:0.4rem;font-family:'Karla',sans-serif;font-size:0.88rem;font-weight:500;cursor:pointer;transition:opacity 0.2s;}
  .login-btn:hover{opacity:0.85;}
  .login-error{font-size:0.72rem;color:#e07070;margin-top:0.75rem;display:none;text-align:center;}
  .login-divider{text-align:center;font-size:0.72rem;color:var(--muted);margin:1.25rem 0;}

  /* DASHBOARD */
  .dashboard{display:none;}
  .topbar{background:var(--surface);border-bottom:1px solid var(--border);padding:1rem 2rem;display:flex;justify-content:space-between;align-items:center;position:sticky;top:0;z-index:100;}
  .topbar-logo{font-family:'Syne',sans-serif;font-size:1rem;font-weight:700;}
  .topbar-logo span{color:var(--rust);}
  .topbar-right{display:flex;align-items:center;gap:1rem;}
  .topbar-biz{font-size:0.8rem;color:var(--muted);}
  .logout-btn{font-size:0.65rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);background:none;border:1px solid var(--border);padding:0.4rem 0.8rem;border-radius:0.2rem;cursor:pointer;font-family:'Karla',sans-serif;transition:all 0.2s;}
  .logout-btn:hover{color:var(--text);border-color:var(--muted);}

  .stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--border);border-bottom:1px solid var(--border);}
  .stat-box{background:var(--surface);padding:1.5rem 2rem;}
  .stat-label{font-size:0.62rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--muted);margin-bottom:0.4rem;display:block;}
  .stat-value{font-family:'Syne',sans-serif;font-size:2rem;font-weight:800;line-height:1;}
  .stat-value.rust{color:var(--rust);}
  .stat-value.gold{color:var(--gold);}
  .stat-value.sage{color:var(--sage);}
  .stat-sub{font-size:0.62rem;color:var(--muted);margin-top:0.25rem;}

  .content{max-width:1100px;margin:0 auto;padding:2rem;}
  .grid-2{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-bottom:1.5rem;}

  .card{background:var(--surface);border:1px solid var(--border);border-radius:0.5rem;padding:1.5rem;}
  .card-title{font-family:'Syne',sans-serif;font-size:0.78rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--muted);margin-bottom:1.25rem;}

  .click-row{display:flex;justify-content:space-between;align-items:center;padding:0.6rem 0;border-bottom:1px solid var(--dim);font-size:0.82rem;}
  .click-row:last-child{border-bottom:none;}
  .click-type{display:flex;align-items:center;gap:0.5rem;}
  .click-count{font-family:'Syne',sans-serif;font-size:0.9rem;font-weight:700;color:var(--rust);}

  /* AI SUGGESTIONS */
  .ai-card{background:var(--surface);border:1px solid rgba(196,98,45,0.25);border-radius:0.5rem;padding:1.5rem;margin-bottom:1.5rem;}
  .ai-card-label{font-size:0.62rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--rust);margin-bottom:1rem;display:block;font-weight:500;}
  .suggestion-item{display:flex;gap:0.75rem;padding:0.75rem 0;border-bottom:1px solid var(--dim);font-size:0.85rem;line-height:1.6;color:rgba(232,228,220,0.7);}
  .suggestion-item:last-child{border-bottom:none;}
  .suggestion-num{color:var(--rust);font-family:'Syne',sans-serif;font-weight:700;flex-shrink:0;margin-top:0.1rem;}
  .ai-loading{display:flex;align-items:center;gap:0.5rem;font-size:0.82rem;color:var(--muted);font-style:italic;}

  /* PROFILE PREVIEW */
  .profile-link-box{background:var(--dim);border-radius:0.4rem;padding:0.85rem 1rem;display:flex;align-items:center;justify-content:space-between;gap:1rem;margin-bottom:1rem;}
  .profile-link-url{font-size:0.78rem;color:var(--rust);word-break:break-all;font-family:'DM Mono',monospace;}
  .copy-btn{background:var(--rust);color:white;border:none;padding:0.4rem 0.85rem;border-radius:0.3rem;font-family:'Karla',sans-serif;font-size:0.72rem;cursor:pointer;white-space:nowrap;transition:opacity 0.2s;}
  .copy-btn:hover{opacity:0.8;}

  .edit-link{display:inline-block;background:transparent;color:var(--muted);border:1px solid var(--border);padding:0.5rem 1.25rem;border-radius:0.3rem;font-size:0.75rem;text-decoration:none;transition:all 0.2s;font-family:'Karla',sans-serif;letter-spacing:0.05em;}
  .edit-link:hover{color:var(--text);border-color:var(--muted);}

  .promote-box{background:linear-gradient(135deg,rgba(196,98,45,0.15),rgba(212,168,67,0.1));border:1px solid rgba(196,98,45,0.2);border-radius:0.5rem;padding:1.5rem;}
  .promote-box h3{font-family:'Syne',sans-serif;font-size:1rem;font-weight:700;margin-bottom:0.4rem;}
  .promote-box p{font-size:0.8rem;color:var(--muted);line-height:1.6;margin-bottom:1rem;}
  .promote-btn-gold{background:var(--gold);color:var(--bg);border:none;padding:0.65rem 1.5rem;border-radius:2rem;font-family:'Karla',sans-serif;font-size:0.82rem;font-weight:600;cursor:pointer;transition:opacity 0.2s;}
  .promote-btn-gold:hover{opacity:0.88;}

  .spinner{width:16px;height:16px;border:2px solid var(--border);border-top-color:var(--rust);border-radius:50%;animation:spin 0.7s linear infinite;display:inline-block;}
  @keyframes spin{to{transform:rotate(360deg);}}

  @media(max-width:768px){
    .stats-row{grid-template-columns:1fr 1fr;}
    .grid-2{grid-template-columns:1fr;}
    .content{padding:1rem;}
  }
</style>
</head>
<body>

<!-- LOGIN -->
<div id="loginScreen" class="login-screen">
  <div class="login-box">
    <div class="login-logo">Julesk<span>Local</span></div>
    <div class="login-sub">Business Dashboard</div>
    <label class="login-label">Your Business Slug</label>
    <input type="text" class="login-input" id="slugInput" placeholder="your-business-name-abc12">
    <label class="login-label">Access Code</label>
    <input type="password" class="login-input" id="codeInput" placeholder="Enter your access code" onkeydown="if(event.key==='Enter')login()">
    <button class="login-btn" onclick="login()">View My Dashboard →</button>
    <div class="login-error" id="loginError">Business not found. Check your slug and code.</div>
    <div class="login-divider">Don't have a listing yet?</div>
    <a href="list-your-business.html" style="display:block;text-align:center;color:var(--rust);font-size:0.85rem;text-decoration:none;">Create your free listing →</a>
  </div>
</div>

<!-- DASHBOARD -->
<div id="dashboard" class="dashboard">
  <div class="topbar">
    <div class="topbar-logo">Julesk<span>Local</span> <span style="color:var(--muted);font-size:0.7rem;font-family:'DM Mono',monospace;font-weight:300;margin-left:0.5rem;">/ dashboard</span></div>
    <div class="topbar-right">
      <span class="topbar-biz" id="topbarBiz"></span>
      <button class="logout-btn" onclick="logout()">Log Out</button>
    </div>
  </div>

  <div class="stats-row">
    <div class="stat-box"><span class="stat-label">Profile Views</span><div class="stat-value rust" id="statViews">—</div><div class="stat-sub">all time</div></div>
    <div class="stat-box"><span class="stat-label">Link Clicks</span><div class="stat-value gold" id="statClicks">—</div><div class="stat-sub">all time</div></div>
    <div class="stat-box"><span class="stat-label">Listing Status</span><div class="stat-value sage" id="statStatus">—</div><div class="stat-sub" id="statStatusSub"></div></div>
    <div class="stat-box"><span class="stat-label">Member Since</span><div class="stat-value" id="statSince" style="font-size:1rem;padding-top:0.5rem;">—</div><div class="stat-sub">JuleskLocal</div></div>
  </div>

  <div class="content">

    <!-- AI SUGGESTIONS -->
    <div class="ai-card">
      <span class="ai-card-label">Claude's suggestions to improve your listing</span>
      <div id="aiSuggestions"><div class="ai-loading"><div class="spinner"></div><span>Analyzing your listing...</span></div></div>
    </div>

    <div class="grid-2">
      <!-- ANALYTICS -->
      <div class="card">
        <div class="card-title">Link Clicks Breakdown</div>
        <div id="clickBreakdown"><div style="font-size:0.8rem;color:var(--muted);">No clicks recorded yet.</div></div>
      </div>

      <!-- PROFILE -->
      <div class="card">
        <div class="card-title">Your Public Profile</div>
        <div class="profile-link-box">
          <span class="profile-link-url" id="profileUrl"></span>
          <button class="copy-btn" onclick="copyProfile()">Copy</button>
        </div>
        <a id="viewProfileLink" href="#" target="_blank" class="edit-link">View Public Profile →</a>
      </div>
    </div>

    <!-- PROMOTE -->
    <div class="promote-box">
      <h3>Get more visibility</h3>
      <p>Promoted listings appear at the top of all search results in your category. More eyes on your business, more customers through the door.</p>
      <button class="promote-btn-gold" onclick="alert('Paid promotion coming soon! We will email you when it launches.')">Boost My Listing — Coming Soon</button>
    </div>

  </div>
</div>

<script>
  const SUPABASE_URL = 'https://kmugbwcwonygkzkiblqf.supabase.co';
  const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImttdWdid2N3b255Z2t6a2libHFmIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzc4MDUyNDQsImV4cCI6MjA5MzM4MTI0NH0.JypfbLZ1HkLHMlAvAzzo98yi3WOdnatZPCmxMDG6dNk';
  const { createClient } = supabase;
  const db = createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

  // Simple access: slug is the business slug, code is last 5 chars of their ID
  // (we show this to them on their success page — for now use slug only)
  const ACCESS_CODE = 'julesk2026'; // shared beta code — change per user later

  let currentBiz = null;

  async function login() {
    const slug = document.getElementById('slugInput').value.trim();
    const code = document.getElementById('codeInput').value.trim();
    const err = document.getElementById('loginError');
    err.style.display = 'none';

    if (code !== ACCESS_CODE) { err.style.display = 'block'; return; }

    const { data, error } = await db.from('businesses').select('*').eq('slug', slug).single();
    if (error || !data) { err.style.display = 'block'; return; }

    currentBiz = data;
    showDashboard(data);
  }

  function logout() {
    document.getElementById('loginScreen').style.display = 'flex';
    document.getElementById('dashboard').style.display = 'none';
    currentBiz = null;
  }

  async function showDashboard(biz) {
    document.getElementById('loginScreen').style.display = 'none';
    document.getElementById('dashboard').style.display = 'block';
    document.getElementById('topbarBiz').textContent = biz.business_name;

    // Profile URL
    const url = `https://julesk.online/biz.html?slug=${biz.slug}`;
    document.getElementById('profileUrl').textContent = url;
    document.getElementById('viewProfileLink').href = url;

    // Since date
    document.getElementById('statSince').textContent = new Date(biz.created_at).toLocaleDateString('en-US',{month:'short',year:'numeric'});

    // Status
    document.getElementById('statStatus').textContent = biz.is_promoted ? 'Featured' : 'Active';
    document.getElementById('statStatusSub').textContent = biz.is_promoted ? 'promoted listing' : 'standard listing';

    // Views
    const { count: views } = await db.from('profile_views').select('*',{count:'exact',head:true}).eq('business_id',biz.id);
    document.getElementById('statViews').textContent = views || 0;

    // Clicks
    const { data: clicks } = await db.from('link_clicks').select('link_type').eq('business_id',biz.id);
    document.getElementById('statClicks').textContent = clicks?.length || 0;

    // Click breakdown
    if (clicks && clicks.length > 0) {
      const counts = {};
      clicks.forEach(c => { counts[c.link_type] = (counts[c.link_type] || 0) + 1; });
      const icons = { website:'🌐', phone:'📞', scheduler:'📅', pricing:'💰' };
      document.getElementById('clickBreakdown').innerHTML = Object.entries(counts)
        .sort((a,b) => b[1]-a[1])
        .map(([type, count]) => `
          <div class="click-row">
            <span class="click-type">${icons[type]||'🔗'} ${type.charAt(0).toUpperCase()+type.slice(1)}</span>
            <span class="click-count">${count}</span>
          </div>`).join('');
    }

    generateSuggestions(biz, views || 0, clicks?.length || 0);
  }

  async function generateSuggestions(biz, views, clicks) {
    const el = document.getElementById('aiSuggestions');
    try {
      const missing = [];
      if (!biz.description) missing.push('description');
      if (!biz.phone) missing.push('phone number');
      if (!biz.website) missing.push('website');
      if (!biz.pricing_link) missing.push('pricing link');
      if (!biz.scheduler_link) missing.push('scheduler/booking link');
      if (!biz.instagram && !biz.facebook && !biz.tiktok) missing.push('social media links');

      const prompt = `You are an advisor for JuleskLocal, a community business directory. Give this business owner 3 specific, actionable suggestions to get more customers from their listing. Be direct and practical.

Business: ${biz.business_name}
Category: ${biz.category}
City: ${biz.city}
Profile views: ${views}
Link clicks: ${clicks}
Missing from profile: ${missing.length ? missing.join(', ') : 'nothing — profile is complete!'}
Has description: ${!!biz.description}
Has booking link: ${!!biz.scheduler_link}
Has pricing link: ${!!biz.pricing_link}
Has social media: ${!!(biz.instagram||biz.facebook||biz.tiktok||biz.youtube)}

Return ONLY a numbered list of 3 suggestions. Each one sentence. No intro text.`;

      const response = await fetch('https://api.anthropic.com/v1/messages', {
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ model:'claude-sonnet-4-20250514', max_tokens:400, messages:[{role:'user',content:prompt}] })
      });
      const data = await response.json();
      const text = data.content?.find(b=>b.type==='text')?.text || '';
      const lines = text.split('\n').filter(l => l.trim()).slice(0,3);
      el.innerHTML = lines.map((l,i) => `<div class="suggestion-item"><span class="suggestion-num">${i+1}</span><span>${l.replace(/^\d+\.\s*/,'')}</span></div>`).join('');
    } catch {
      el.innerHTML = `
        <div class="suggestion-item"><span class="suggestion-num">1</span><span>Add a booking link so customers can schedule directly from your profile.</span></div>
        <div class="suggestion-item"><span class="suggestion-num">2</span><span>Add your pricing link to build trust and attract serious customers.</span></div>
        <div class="suggestion-item"><span class="suggestion-num">3</span><span>Connect your social media to let customers follow you after visiting your profile.</span></div>`;
    }
  }

  function copyProfile() {
    navigator.clipboard.writeText(document.getElementById('profileUrl').textContent);
    document.querySelector('.copy-btn').textContent = 'Copied!';
    setTimeout(()=>document.querySelector('.copy-btn').textContent='Copy',2000);
  }
</script>
</body>
</html>
